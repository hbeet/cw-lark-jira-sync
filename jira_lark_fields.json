  {
    "name": "开发预估工期",
    "type": "text"
  },
  {
    "name": "延期状态",
    "type": "select",
    "multiple": false,
    "options": [
      {
        "name": "无提交验收时间"
      },
      {
        "name": "未延期"
      },
      {
        "name": "已延期"
      },
      {
        "name": "已完成延期"
      }
    ]
  },
  {
    "name": "延期原因",
    "type": "text"
  },
  {
    "name": "延期时长",
    "type": "formula",
    "expression": "IF(OR(ISBLANK([原提交验收时间]), ISBLANK([最新提交验收时间])), \"\", IF(DAYS([最新提交验收时间], [原提交验收时间]) > 0, TEXT(DAYS([最新提交验收时间], [原提交验收时间]), \"0\") & \"天\", \"\"))"
  }
]
