# Copy these values into:
# /Users/<you>/.config/jira-lark-sync/env
#
# Keep the real env file private. Do not commit or share it.

# Local service
export PORT=8787
export SYNC_SECRET=replace-with-a-long-random-string

# Jira
export JIRA_BASE_URL=https://jira.legenddigital.work
export JIRA_TOKEN=replace-with-your-jira-token
export JIRA_JQL='project = CW order by updated desc'
export JIRA_MAX=500
export JIRA_PAGE_SIZE=50
export JIRA_REACHABILITY_CHECK_ENABLED=1
export JIRA_REACHABILITY_TIMEOUT_MS=5000

# Lark Base
export LARK_BASE_TOKEN=replace-with-your-base-token
export LARK_TABLE_ID=replace-with-default-table-id
export LARK_AS=user

# Lark event listener
export LARK_EVENT_ENABLED=1
export LARK_APP_ID=replace-with-your-lark-app-id
export LARK_EVENT_PYTHON=/Users/you/.local/share/jira-lark-sync/.venv-lark-sdk/bin/python

# Incremental refresh
export LARK_INCREMENTAL_REFRESH_ENABLED=1
export LARK_INCREMENTAL_REFRESH_SECONDS=21600
export LARK_INCREMENTAL_JQL_WINDOW=-6h
export LARK_INCREMENTAL_RETRY_WHEN_UNREACHABLE_SECONDS=300

# Runtime files
export LARK_SYNC_CACHE_PATH=/Users/you/.local/share/jira-lark-sync/cache/index.json
export LARK_SYNC_DB_PATH=/Users/you/.local/share/jira-lark-sync/cache/sync.db
export LARK_USER_MAP_FILE=/Users/you/.local/share/jira-lark-sync/lark_user_map.tsv
export JIRA_LARK_TABLE_CONFIG=config/tables.json

# Queue and batch settings
export LARK_JOB_MAX_ATTEMPTS=4
export LARK_BATCH_SYNC_ENABLED=1
export LARK_BATCH_SYNC_SIZE=50
export LARK_BATCH_DISPATCH_DELAY_MS=1500
export LARK_NATIVE_BATCH_UPDATE=1
export LARK_NATIVE_BATCH_CHUNK_SIZE=200
export LARK_RUNNING_JOB_STALE_SECONDS=60

# Logs and startup checks
export SYNC_LOG_RETENTION_DAYS=14
export SYNC_LOG_RETENTION_MAX_FILES=300
export STARTUP_READINESS_CHECK_ENABLED=1
export STARTUP_READINESS_MAX_SECONDS=120
export STARTUP_READINESS_INTERVAL_SECONDS=15
